{
  "name": "getgloss",
  "version": "0.8.0",
  "description": "Local browser-based diff review for coding-agent loops.",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "getgloss": "./dist/cli/index.js",
    "gloss": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:web && pnpm build:node",
    "build:web": "vite build",
    "build:node": "tsup",
    "check": "biome check .",
    "format": "biome format --write .",
    "prepack": "pnpm build",
    "dev:web": "vite --host 127.0.0.1",
    "setup": "tsx scripts/dev-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@shikijs/langs": "4.1.0",
    "@shikijs/themes": "4.1.0",
    "@tailwindcss/vite": "4.3.0",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "get-port": "7.2.0",
    "hono": "4.12.21",
    "lucide-react": "1.16.0",
    "open": "10.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "4.1.0",
    "ulid": "3.0.2",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.3.0",
    "tsup": "8.5.1",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  },
  "keywords": [
    "diff",
    "review",
    "coding-agents"
  ],
  "author": "Raj Joshi",
  "license": "MIT",
  "homepage": "https://getgloss.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamrajjoshi/gloss.git"
  },
  "bugs": {
    "url": "https://github.com/iamrajjoshi/gloss/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
